  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Durante anos, essa fazenda ficou esquecida.\nA terra endureceu, as cercas
    ca\xEDram, e ningu\xE9m se importou o suficiente para consertar.\n\nO governo
    decidiu que algu\xE9m precisava cuidar disso.\nE, por algum motivo, esse algu\xE9m
    foi voc\xEA.\n\nN\xE3o \xE9 muito.\nMas \xE9 sua.\nE talvez\u2026 seja suficiente
    para recome\xE7ar"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: b993c46cbb1ac4343bb913cecf950f72, type: 2}
