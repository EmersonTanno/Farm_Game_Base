  m_Script: {fileID: 11500000, guid: a074707f1bfa28c45a80923c934d14fd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  mainCanvas: {fileID: 935840279}
  buttons: {fileID: 128404923}
  loadCanvas: {fileID: 209732130}
  mainAnimator: {fileID: 935840281}
  saveLoadAnimator: {fileID: 209732132}
  configsAnimator: {fileID: 1375702122}
  newGameScene: SampleScene
  loadGameScene: LoadGameHouse
  canvasRect: {fileID: 1011872061}
  startNewGame: 0
  textTransform: {fileID: 1193484589}
  scrollSpeed: 100
  backGroundIntro: {fileID: 528213425}
  backGroundIntroObj: {fileID: 528213423}
  fadeSpeed: 1
  introArea: {fileID: 1193484590}
  ptText: "Durante anos, essa fazenda ficou esquecida.\nA terra endureceu, as cercas
    ca\xEDram, e ningu\xE9m se importou o suficiente para consertar.\n\nO governo
    decidiu que algu\xE9m precisava cuidar disso.\nE, por algum motivo, esse algu\xE9m
    foi voc\xEA.\n\nN\xE3o \xE9 muito.\nMas \xE9 sua.\nE talvez\u2026 seja suficiente
    para recome\xE7ar"
  enText: "For years, this farm stayed forgotten.\nThe land hardened, the fences
    fell, and no one cared enough to fix them.\n\nThe government decided someone
    had to take responsibility.\nAnd, for some reason, that someone was you.\n\nIt\u2019s
    not much.\nBut it\u2019s yours.\nAnd maybe\u2026 it\u2019s enough to start over."
  loadGame: 0
  languageSelector: {fileID: 38990768}
