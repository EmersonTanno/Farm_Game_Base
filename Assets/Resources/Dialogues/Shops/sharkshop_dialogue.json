          "textLinePt": "Hmm... que pena.",
          "textLineEn": "Hmm... what a shame."
        },
        {
          "portrait": "shark",
          "textLinePt": "Eu estava começando a gostar de você devendo.",
          "textLineEn": "I was starting to like you owing me."
