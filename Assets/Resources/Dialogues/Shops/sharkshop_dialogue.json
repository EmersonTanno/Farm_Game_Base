    },

    {
      "dialogueId": "PayDebt2",
      "dialogueLines": [
        {
          "portrait": "shark",
          "textLinePt": "Sem pressa.",
          "textLineEn": "No rush."
        },
        {
          "portrait": "shark",
          "textLinePt": "Dívidas costumam crescer melhor com o tempo.",
          "textLineEn": "Debts tend to grow better with time."
        },
        {
          "portrait": "shark",
          "textLinePt": "E eu sou paciente.",
          "textLineEn": "And I'm patient."
        }
      ]
    },

    {
      "dialogueId": "CantPayDebt",
      "dialogueLines": [
        {
          "portrait": "shark",
          "textLinePt": "Sem dinheiro... de novo?",
          "textLineEn": "No money... again?"
        },
        {
          "portrait": "shark",
          "textLinePt": "Não tem problema.",
          "textLineEn": "Not a problem."
        },
        {
          "portrait": "shark",
          "textLinePt": "Isso só torna tudo mais interessante.",
